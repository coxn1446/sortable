{
  "name": "sortable",
  "version": "0.1.0",
  "private": true,
  "description": "Sortable - app shell built with React (Vite), Express, and PostgreSQL.",
  "main": "serverIndex.js",
  "scripts": {
    "start": "node serverIndex.js",
    "dev": "node scripts/dev.js",
    "start:dev": "vite --host",
    "server:dev": "nodemon --config nodemon.json serverIndex.js",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:qa": "gcloud run deploy sortable-qa --source . --region=us-central1 --update-env-vars=NODE_ENV=production,ENVIRONMENT=qa,DEFAULT_CLIENT_URL=https://qa.sortable.net",
    "deploy:prod": "gcloud run deploy sortable --source . --region=us-central1 --update-env-vars=NODE_ENV=production,ENVIRONMENT=production,DEFAULT_CLIENT_URL=https://sortable.net",
    "test": "jest",
    "s": "npx cap sync ios",
    "check-secrets": "node scripts/check-secrets.js",
    "ngrok": "ngrok http http://127.0.0.1:3000"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/space-grotesk": "^5.1.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.14.0",
    "@ionic/react": "^8.4.0",
    "@reduxjs/toolkit": "^2.5.0",
    "@tailwindcss/vite": "^4.1.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.5",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "firebase-admin": "^12.7.0",
    "ionicons": "^7.4.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.2",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^4.1.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@capacitor/cli": "^6.2.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-jest": "^29.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.9",
    "vite": "^5.4.11"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
