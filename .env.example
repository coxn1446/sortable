# Copy to .env for local development. Production secrets should live in
# Google Cloud Secret Manager and be loaded by server/utils/secrets.js.

NODE_ENV=development
# ENVIRONMENT controls which Postgres schema is used:
#   production -> public
#   qa         -> qa
#   anything else (including "development") -> public
ENVIRONMENT=development
PORT=8080

# Session
SESSION_SECRET=replace-with-a-long-random-string

# Database (local Postgres for dev; point to Cloud SQL / Neon / Supabase for prod)
DB_HOST=localhost
DB_PORT=5432
DB_USER=sortable
DB_PASSWORD=sortable
DB_DATABASE=sortable

# Default client URL — browser origin used in OAuth redirect URIs (Vite dev is :3000; API is :8080 with /api proxied).
# For Sign in with Apple over HTTPS while developing locally: run `npm run ngrok` (install ngrok CLI + authtoken first),
# copy the printed https://….ngrok-free.dev base URL, set DEFAULT_CLIENT_URL to that value, and add the domain +
# return URL `{$DEFAULT_CLIENT_URL}/api/auth/apple/callback` in your Apple Services ID.
DEFAULT_CLIENT_URL=http://localhost:3000

# OAuth - Google (optional in dev; strategy is skipped if values are missing)
# In Google Cloud Console, register redirect URIs: {DEFAULT_CLIENT_URL}/api/auth/google/callback per env (see ARCHITECTURE.md).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - Apple (optional in dev; strategy is skipped if values are missing)
# APPLE_KEY: .p8 PEM. Do NOT use unquoted multiline — dotenv will only read the first line.
#   Option A — one line with escaped newlines:
# APPLE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAg...\n-----END PRIVATE KEY-----"
#   Option B — double-quoted multiline (real line breaks inside the quotes):
# APPLE_KEY="-----BEGIN PRIVATE KEY-----
# MIGTAg...
# -----END PRIVATE KEY-----"
#   Option C (recommended local dev): path to Apple `AuthKey_<KEYID>.p8` from disk (`secrets/` is gitignored):
# APPLE_KEY_FILE=./secrets/AuthKey_XXXXXXXXXX.p8
# Make sure APPLE_KEY_ID matches Apple’s Key ID (same as in the filename). Omit or leave APPLE_KEY empty when using a file.
# Verbose Apple Sign In diagnostics on server boot + OAuth token error logs (all envs): DEBUG_APPLE_AUTH=1
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_KEY=

# Google Cloud Storage (optional; uploads fall back to local /uploads in dev)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_CLOUD_STORAGE_KEY=

# Firebase Admin (optional; push notifications are no-op without it)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Vite-exposed (must be prefixed with VITE_ to reach the browser)
# VITE_GOOGLE_PLACES_API_KEY=
